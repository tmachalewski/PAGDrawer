# Copy to .env (gitignored) and adjust as needed.

# MongoDB connection string.
# For the default docker-compose mongo container:
MONGODB_URI=mongodb://localhost:27017

# Database name inside MongoDB.
MONGODB_DB=pagdrawer

# Skip the MongoDB connection check during app startup.
# Useful when running pytest without a live Mongo instance.
# PAGDRAWER_SKIP_MONGO=1
